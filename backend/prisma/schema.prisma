generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RiskAssessment {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  industry        String   @map("industry") @db.VarChar(100)
  dataType        String   @map("data_type") @db.VarChar(100)
  encryption      String   @map("encryption") @db.VarChar(100)
  dataLifetime    Int      @map("data_lifetime")
  riskScore       Int      @map("risk_score")
  riskLevel       String   @map("risk_level") @db.VarChar(50)
  recommendations Json
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation("RiskAssessments", fields: [userId], references: [id], onDelete: Cascade)
  reports         Report[]

  @@map("risk_assessments")
}

model LabSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  pValue         Int      @map("p_value")
  qValue         Int      @map("q_value")
  eValue         Int      @map("e_value")
  nValue         Int      @map("n_value")
  phiN           Int      @map("phi_n")
  privateKeyD    Int      @map("private_key_d")
  keySizeBits    Int      @map("key_size_bits")
  classicalTimeMs Decimal @map("classical_time_ms") @db.Decimal(10, 2)
  quantumSteps   Int      @map("quantum_steps")
  quantumTimeMs  Decimal  @map("quantum_time_ms") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation("LabSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@map("lab_sessions")
}

model Report {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  assessmentId String         @map("assessment_id") @db.Uuid
  fileUrl      String         @map("file_url") @db.VarChar(500)
  createdAt    DateTime       @default(now()) @map("created_at")
  user         User           @relation("Reports", fields: [userId], references: [id], onDelete: Cascade)
  assessment   RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("reports")
}

// ================ ADVANCED FEATURES - NEW TABLES ================

// FEATURE 1: THREAT INTELLIGENCE FEED
model ThreatItem {
  id                 String   @id @default(uuid()) @db.Uuid
  title              String   @db.VarChar(500)
  summary            String   @db.Text
  source             String   @db.VarChar(200)
  category           String   @db.VarChar(100) // 'advisory' | 'research' | 'breach' | 'vendor'
  severity           String   @db.VarChar(50) // 'low' | 'medium' | 'high' | 'critical'
  url                String   @db.VarChar(500)
  affectedAlgorithms String[] @map("affected_algorithms") // Real DB array
  impact             String?  @db.Text
  recommendation     String?  @db.Text
  cveId              String?  @map("cve_id") @db.VarChar(50)
  publishedAt        DateTime @map("published_at")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("threat_items")
}

model ThreatSubscription {
  id                  String   @id @default(uuid()) @db.Uuid
  email               String   @db.VarChar(255)
  severityThreshold   String   @map("severity_threshold") @db.VarChar(50)
  verified            Boolean  @default(false)
  verificationToken   String?  @map("verification_token") @db.VarChar(255)
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("threat_subscriptions")
}

model UnsubscribeFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @db.VarChar(255)
  reason    String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("unsubscribe_feedbacks")
}

// FEATURE 2: CRYPTOGRAPHY SCANNER & ASSET MANAGEMENT
model Asset {
  id                    String       @id @default(uuid()) @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  organizationId        String?      @map("organization_id") @db.Uuid
  name                  String       @db.VarChar(255)
  assetType             String       @map("asset_type") @db.VarChar(50) // 'github' | 'git' | 'website' | 'ssl' | 'local' | 'cloud' | 'sbom'
  repositoryUrl         String?      @map("repository_url") @db.VarChar(500)
  domain                String?      @db.VarChar(255)
  description           String?      @db.Text
  tags                  String[]
  status                String       @default("active") @db.VarChar(50) // 'active' | 'archived' | 'deleted'
  currentRiskScore      Int?         @map("current_risk_score")
  currentQuantumReadiness Int?       @map("current_quantum_readiness")
  latestScanId          String?      @map("latest_scan_id") @db.Uuid
  metadata              Json?        @db.JsonB
  lastScanAt            DateTime?    @map("last_scan_at")
  nextScheduledScanAt   DateTime?    @map("next_scheduled_scan_at")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  user                  User         @relation("Assets", fields: [userId], references: [id], onDelete: Cascade)
  scanResults           ScanResult[] @relation("AssetScans")
  events                AssetEvent[] @relation("AssetEvents")
  snapshots             AssetSnapshot[] @relation("AssetSnapshots")
  jobs                  Job[]        @relation("AssetJobs")
  workflowRuns          WorkflowRun[] @relation("AssetWorkflowRuns")

  @@map("assets")
}

model AssetEvent {
  id               String   @id @default(uuid()) @db.Uuid
  assetId          String   @map("asset_id") @db.Uuid
  eventType        String   @map("event_type") @db.VarChar(100)
  title            String   @db.VarChar(255)
  description      String   @db.Text
  severity         String   @db.VarChar(50) // 'info' | 'warning' | 'critical'
  sourceModule     String   @map("source_module") @db.VarChar(100) // 'scanner' | 'threat-intel' | 'compliance' | 'system'
  eventData        Json?    @map("event_data") @db.JsonB
  createdByUserId  String?  @map("created_by_user_id") @db.Uuid
  systemGenerated  Boolean  @default(true) @map("system_generated")
  createdAt        DateTime @default(now()) @map("created_at")

  asset            Asset    @relation("AssetEvents", fields: [assetId], references: [id], onDelete: Cascade)
  user             User?    @relation("UserEvents", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt(sort: Desc)])
  @@map("asset_events")
}

model AssetSnapshot {
  id                    String   @id @default(uuid()) @db.Uuid
  assetId               String   @map("asset_id") @db.Uuid
  scanResultId          String?  @map("scan_result_id") @db.Uuid
  overallRiskScore      Int      @map("overall_risk_score")
  quantumReadinessScore Int      @map("quantum_readiness_score")
  criticalFindings      Int      @map("critical_findings")
  highFindings          Int      @map("high_findings")
  mediumFindings        Int      @map("medium_findings")
  lowFindings           Int      @map("low_findings")
  algorithmSummary      Json     @map("algorithm_summary") @db.JsonB
  capturedAt            DateTime @default(now()) @map("captured_at")

  asset                 Asset    @relation("AssetSnapshots", fields: [assetId], references: [id], onDelete: Cascade)
  scanResult            ScanResult? @relation("SnapshotScan", fields: [scanResultId], references: [id], onDelete: SetNull)

  @@index([assetId, capturedAt(sort: Desc)])
  @@map("asset_snapshots")
}

model ScanResult {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  assetId     String?  @map("asset_id") @db.Uuid
  scanType    String   @map("scan_type") @db.VarChar(50) // 'url' | 'code' | 'api'
  inputTarget String   @map("input_target") @db.Text
  findings    Json     @db.JsonB
  overallScore Int     @map("overall_score")
  riskLevel   String   @map("risk_level") @db.VarChar(50)
  scannedAt   DateTime @default(now()) @map("scanned_at")
  user        User     @relation("ScanResults", fields: [userId], references: [id], onDelete: Cascade)
  asset       Asset?   @relation("AssetScans", fields: [assetId], references: [id], onDelete: SetNull)
  snapshots   AssetSnapshot[] @relation("SnapshotScan")

  @@map("scan_results")
}

// FEATURE 3: Q-DAY PROBABILITY METER
model QDayData {
  id        String   @id @default(uuid()) @db.Uuid
  dataType  String   @map("data_type") @db.VarChar(100) // 'probability' | 'milestone' | 'prediction'
  value     Json     @db.JsonB
  source    String   @db.VarChar(200)
  recordedAt DateTime @map("recorded_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("qday_data")
}

model QuantumMilestone {
  id             String   @id @default(uuid()) @db.Uuid
  company        String   @db.VarChar(100)
  qubitCount     Int      @map("qubit_count")
  year           Int
  milestoneName  String   @map("milestone_name") @db.VarChar(200)
  description    String   @db.Text
  sourceUrl      String   @map("source_url") @db.VarChar(500)

  @@map("quantum_milestones")
}

// FEATURE 4: MIGRATION PLANNER
model MigrationPlan {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  companyInfo  Json     @map("company_info") @db.JsonB
  currentStack Json     @map("current_stack") @db.JsonB
  dataInventory Json    @map("data_inventory") @db.JsonB
  priorities   Json     @db.JsonB
  generatedPlan Json    @map("generated_plan") @db.JsonB
  totalCostMin Int      @map("total_cost_min")
  totalCostMax Int      @map("total_cost_max")
  timelineMonths Int    @map("timeline_months")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation("MigrationPlans", fields: [userId], references: [id], onDelete: Cascade)

  @@map("migration_plans")
}

// FEATURE 6: COMPLIANCE CHECKER
model ComplianceCheck {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  industry        String   @db.VarChar(100)
  encryptionData  Json     @map("encryption_data") @db.JsonB
  results         Json     @db.JsonB
  overallStatus   String   @map("overall_status") @db.VarChar(50)
  checkedAt       DateTime @default(now()) @map("checked_at")
  user            User     @relation("ComplianceChecks", fields: [userId], references: [id], onDelete: Cascade)

  @@map("compliance_checks")
}

model ComplianceStandard {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @db.VarChar(50) // 'NIST-800-208', 'HIPAA', etc.
  name            String   @db.VarChar(200)
  description     String   @db.Text
  requirements    Json     @db.JsonB
  applicableTo    Json     @map("applicable_to") @db.JsonB // array of industries
  quantumRelevant Boolean  @map("quantum_relevant")
  lastUpdated     DateTime @default(now()) @updatedAt @map("last_updated")

  @@map("compliance_standards")
}

// FEATURE 7: COMMUNITY & LEADERBOARD
model UserPoints {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  points    Int      @default(0)
  level     String   @db.VarChar(50)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation("UserPoints", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model QuizAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  quizId     String   @map("quiz_id") @db.Uuid
  score      Int
  total      Int
  percentage Decimal  @db.Decimal(5, 2)
  timeTaken  Int      @map("time_taken") // seconds
  answers    Json     @db.JsonB
  completedAt DateTime @default(now()) @map("completed_at")
  user       User     @relation("QuizAttempts", fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model UserBadge {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  badgeId  String   @map("badge_id") @db.VarChar(100)
  earnedAt DateTime @default(now()) @map("earned_at")
  user     User     @relation("UserBadges", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_badges")
}

model Quiz {
  id         String   @id @default(uuid()) @db.Uuid
  title      String   @db.VarChar(200)
  topic      String   @db.VarChar(100)
  difficulty String   @db.VarChar(50)
  points     Int
  questions  Json     @db.JsonB
  isActive   Boolean  @default(true) @map("is_active")

  @@map("quizzes")
}

// FEATURE 8: QUANTUMBOT CHATBOT
model ChatSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  messages  ChatMessage[]
  user      User     @relation("ChatSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String   @db.VarChar(20) // 'user' | 'assistant'
  content   String   @db.Text
  tokensUsed Int     @map("tokens_used")
  createdAt DateTime @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// Add relations to User model
model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique @db.VarChar(255)
  passwordHash    String           @map("password_hash") @db.VarChar(255)
  name            String?          @db.VarChar(255)
  avatar          String?          @db.VarChar(50)
  knowledgeLevel  String           @default("beginner") @map("knowledge_level") @db.VarChar(50)
  role            String           @default("free") @db.VarChar(50)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  riskAssessments RiskAssessment[] @relation("RiskAssessments")
  labSessions     LabSession[]     @relation("LabSessions")
  reports         Report[]         @relation("Reports")
  scanResults     ScanResult[]     @relation("ScanResults")
  migrationPlans  MigrationPlan[]  @relation("MigrationPlans")
  complianceChecks ComplianceCheck[] @relation("ComplianceChecks")
  userPoints      UserPoints?      @relation("UserPoints")
  quizAttempts    QuizAttempt[]    @relation("QuizAttempts")
  userBadges      UserBadge[]      @relation("UserBadges")
  chatSessions    ChatSession[]    @relation("ChatSessions")
  communityThreads CommunityThread[] @relation("ThreadAuthor")
  communityReplies CommunityReply[]  @relation("ReplyAuthor")
  threadUpvotes   ThreadUpvote[]   @relation("UserUpvotes")
  preference      UserPreference?  @relation("UserPreference")
  reportAudits    ReportAudit[]    @relation("ReportAudits")
  assets          Asset[]          @relation("Assets")
  assetEvents     AssetEvent[]     @relation("UserEvents")
  jobs            Job[]            @relation("UserJobs")
  workflowRuns    WorkflowRun[]    @relation("UserWorkflowRuns")

  @@map("users")
}

model Job {
  id                String    @id @default(uuid()) @db.Uuid
  jobType           String    @map("job_type") @db.VarChar(100) // 'scan', 'report', 'compliance'
  jobStatus         String    @map("job_status") @db.VarChar(50) // 'queued', 'waiting', 'running', 'completed', 'failed', 'cancelled'
  priority          Int       @default(0) // Higher number = higher priority
  assetId           String?   @map("asset_id") @db.Uuid
  requestedByUserId String?   @map("requested_by_user_id") @db.Uuid
  queueName         String    @map("queue_name") @db.VarChar(100) // 'scanner', 'reports', 'ai'
  payload           Json      @db.JsonB
  progress          Int       @default(0)
  currentStage      String?   @map("current_stage") @db.VarChar(100)
  attemptCount      Int       @default(0) @map("attempt_count")
  maxAttempts       Int       @default(3) @map("max_attempts")
  
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  failedAt          DateTime? @map("failed_at")
  errorMessage      String?   @map("error_message") @db.Text
  
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  asset             Asset?    @relation("AssetJobs", fields: [assetId], references: [id], onDelete: SetNull)
  user              User?     @relation("UserJobs", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  workflowStepExecution WorkflowStepExecution? @relation("JobExecution")

  @@index([jobStatus, createdAt(sort: Desc)])
  @@index([assetId, createdAt(sort: Desc)])
  @@map("jobs")
}

model Workflow {
  id               String         @id @default(uuid()) @db.Uuid
  workflowName     String         @map("workflow_name") @db.VarChar(150)
  workflowType     String         @map("workflow_type") @db.VarChar(50) // e.g. 'scan_pipeline', 'report_pipeline'
  description      String?        @db.Text
  version          String         @default("1.0.0") @db.VarChar(20)
  enabled          Boolean        @default(true)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  steps            WorkflowStep[] @relation("WorkflowSteps")
  runs             WorkflowRun[]  @relation("WorkflowRuns")

  @@map("workflows")
}

model WorkflowStep {
  id               String         @id @default(uuid()) @db.Uuid
  workflowId       String         @map("workflow_id") @db.Uuid
  stepOrder        Int            @map("step_order")
  stepType         String         @map("step_type") @db.VarChar(50)
  displayName      String         @map("display_name") @db.VarChar(100)
  jobType          String         @map("job_type") @db.VarChar(50)
  configuration    Json?          @db.JsonB
  dependsOnStepId  String?        @map("depends_on_step_id") @db.Uuid
  retryPolicy      Json?          @map("retry_policy") @db.JsonB
  timeoutSeconds   Int?           @map("timeout_seconds")

  workflow         Workflow       @relation("WorkflowSteps", fields: [workflowId], references: [id], onDelete: Cascade)
  dependsOnStep    WorkflowStep?  @relation("StepDependencies", fields: [dependsOnStepId], references: [id], onDelete: SetNull)
  dependentSteps   WorkflowStep[] @relation("StepDependencies")
  executions       WorkflowStepExecution[] @relation("StepExecutions")

  @@map("workflow_steps")
}

model WorkflowRun {
  id               String         @id @default(uuid()) @db.Uuid
  workflowId       String         @map("workflow_id") @db.Uuid
  assetId          String?        @map("asset_id") @db.Uuid
  requestedByUserId String?       @map("requested_by_user_id") @db.Uuid
  status           String         @db.VarChar(50) // 'pending', 'running', 'completed', 'failed', 'aborted'
  currentStep      Int            @default(1) @map("current_step")
  progress         Int            @default(0)
  startedAt        DateTime?      @map("started_at")
  completedAt      DateTime?      @map("completed_at")
  failedAt         DateTime?      @map("failed_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  workflow         Workflow       @relation("WorkflowRuns", fields: [workflowId], references: [id], onDelete: Cascade)
  asset            Asset?         @relation("AssetWorkflowRuns", fields: [assetId], references: [id], onDelete: SetNull)
  user             User?          @relation("UserWorkflowRuns", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  stepExecutions   WorkflowStepExecution[] @relation("RunExecutions")

  @@index([status, createdAt(sort: Desc)])
  @@index([assetId, createdAt(sort: Desc)])
  @@map("workflow_runs")
}

model WorkflowStepExecution {
  id               String         @id @default(uuid()) @db.Uuid
  workflowRunId    String         @map("workflow_run_id") @db.Uuid
  workflowStepId   String         @map("workflow_step_id") @db.Uuid
  jobId            String?        @unique @map("job_id") @db.Uuid
  status           String         @db.VarChar(50) // 'pending', 'running', 'completed', 'failed'
  startedAt        DateTime?      @map("started_at")
  completedAt      DateTime?      @map("completed_at")
  errorMessage     String?        @map("error_message") @db.Text

  run              WorkflowRun    @relation("RunExecutions", fields: [workflowRunId], references: [id], onDelete: Cascade)
  step             WorkflowStep   @relation("StepExecutions", fields: [workflowStepId], references: [id], onDelete: Cascade)
  job              Job?           @relation("JobExecution", fields: [jobId], references: [id], onDelete: SetNull)

  @@map("workflow_step_executions")
}

// ---------------------------------------------------------
// THREAT CORRELATION ENGINE DOMAIN
// ---------------------------------------------------------

model ThreatAdvisory {
  id               String         @id @default(uuid()) @db.Uuid
  source           String         @db.VarChar(100) // NIST, CISA, MITRE, Vendor
  advisoryId       String         @map("advisory_id") @db.VarChar(100) // e.g. CVE-2024-XXXX
  title            String         @db.VarChar(255)
  description      String         @db.Text
  severity         String         @db.VarChar(50)
  publishedAt      DateTime       @map("published_at")
  references       Json           @db.JsonB
  createdAt        DateTime       @default(now()) @map("created_at")

  matches          ThreatMatch[]

  @@unique([source, advisoryId])
  @@map("threat_advisories")
}

model ThreatRule {
  id               String         @id @default(uuid()) @db.Uuid
  ruleId           String         @unique @map("rule_id") @db.VarChar(100) // e.g. RULE-PQC-001
  version          String         @default("1.0.0") @db.VarChar(20)
  title            String         @db.VarChar(255)
  description      String         @db.Text
  severity         String         @db.VarChar(50) // critical, high, medium, low
  priority         Int            @default(0) // Higher is more urgent
  condition        Json           @db.JsonB // Engine logic
  recommendedAction String        @map("recommended_action") @db.Text
  deprecationStatus String?       @map("deprecation_status") @db.VarChar(50) // e.g. 'deprecated', 'disallowed'
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  matches          ThreatMatch[]

  @@map("threat_rules")
}

model ThreatCorrelation {
  id                String         @id @default(uuid()) @db.Uuid
  assetId           String         @map("asset_id") @db.Uuid
  snapshotId        String?        @map("snapshot_id") @db.Uuid
  workflowRunId     String?        @map("workflow_run_id") @db.Uuid
  jobId             String?        @map("job_id") @db.Uuid
  
  status            String         @db.VarChar(50) // 'running', 'completed', 'failed'
  overallSeverity   String?        @map("overall_severity") @db.VarChar(50)
  overallPriority   Int            @default(0) @map("overall_priority")
  overallConfidence Int            @default(0) @map("overall_confidence")
  
  correlatedAt      DateTime       @default(now()) @map("correlated_at")
  createdAt         DateTime       @default(now()) @map("created_at")

  matches           ThreatMatch[]
  recommendations   ThreatRecommendation[]

  @@index([assetId, correlatedAt(sort: Desc)])
  @@map("threat_correlations")
}

model ThreatMatch {
  id               String         @id @default(uuid()) @db.Uuid
  correlationId    String         @map("correlation_id") @db.Uuid
  algorithm        String         @db.VarChar(100)
  algorithmFamily  String?        @map("algorithm_family") @db.VarChar(100)
  findingId        String?        @map("finding_id") @db.VarChar(100)
  threatSource     String         @map("threat_source") @db.VarChar(100) // NIST, Internal Rule, etc.
  advisoryId       String?        @map("advisory_id") @db.Uuid
  ruleId           String?        @map("rule_id") @db.Uuid
  confidence       Int            @default(100)
  severity         String         @db.VarChar(50)
  impact           String?        @db.Text
  affectedComponent String?       @map("affected_component") @db.VarChar(255)
  evidence         Json?          @db.JsonB
  
  createdAt        DateTime       @default(now()) @map("created_at")

  correlation      ThreatCorrelation @relation(fields: [correlationId], references: [id], onDelete: Cascade)
  advisory         ThreatAdvisory?   @relation(fields: [advisoryId], references: [id], onDelete: SetNull)
  rule             ThreatRule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@map("threat_matches")
}

model ThreatRecommendation {
  id                     String         @id @default(uuid()) @db.Uuid
  correlationId          String         @map("correlation_id") @db.Uuid
  recommendationType     String         @map("recommendation_type") @db.VarChar(100) // e.g. 'upgrade_algorithm', 'rotate_key'
  priority               Int            @default(0)
  title                  String         @db.VarChar(255)
  description            String         @db.Text
  estimatedEffort        String         @map("estimated_effort") @db.VarChar(50) // 'Low', 'Medium', 'High'
  estimatedRiskReduction Int            @map("estimated_risk_reduction")
  references             Json?          @db.JsonB
  
  createdAt              DateTime       @default(now()) @map("created_at")

  correlation            ThreatCorrelation @relation(fields: [correlationId], references: [id], onDelete: Cascade)

  @@map("threat_recommendations")
}

// FEATURE 9: COMMUNITY THREADS & REPLIES
model CommunityThread {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(500)
  content   String   @db.Text
  category  String   @db.VarChar(100)
  authorId  String   @map("author_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  views     Int      @default(0)
  upvotes   Int      @default(0)
  tags      String[]

  author    User              @relation("ThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replies   CommunityReply[]  @relation("ThreadReplies")
  userUpvotes ThreadUpvote[]  @relation("ThreadUpvotes")

  @@map("community_threads")
}

model CommunityReply {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  thread    CommunityThread @relation("ThreadReplies", fields: [threadId], references: [id], onDelete: Cascade)
  author    User            @relation("ReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@map("community_replies")
}

model ThreadUpvote {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  thread    CommunityThread @relation("ThreadUpvotes", fields: [threadId], references: [id], onDelete: Cascade)
  user      User            @relation("UserUpvotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("thread_upvotes")
}

// FEATURE 10: AUTOMATED REPORTS
model UserPreference {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  weeklySummary     Boolean  @default(false) @map("weekly_summary")
  monthlyCompliance Boolean  @default(false) @map("monthly_compliance")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation("UserPreference", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model ReportAudit {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  reportType   String   @map("report_type") @db.VarChar(50) // 'weekly_summary' | 'monthly_compliance'
  reportPeriod String   @map("report_period") @db.VarChar(20) // e.g. '2026-W30' or '2026-07'
  status       String   @db.VarChar(20) // 'sent' | 'failed'
  errorLog     String?  @map("error_log") @db.Text
  sentAt       DateTime @default(now()) @map("sent_at")
  user         User     @relation("ReportAudits", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportType, reportPeriod])
  @@index([userId, reportType, reportPeriod])
  @@map("report_audits")
}
